{
  "manifest_version": 3,
  "name": "Verity",
  "version": "1.1.1",
  "description": "Score the sources behind AI responses.",
  "homepage_url": "https://github.com/MustafaAmin06/Verity",
  "permissions": ["tabs", "storage"],
  "host_permissions": [
    "http://localhost:8001/*",
    "http://127.0.0.1:8001/*",
    "https://verity-production-e8f2.up.railway.app/*"
  ],
  "content_security_policy": {
    "extension_pages": "script-src 'self'; object-src 'none'"
  },
  "icons": {
    "128": "icons/icon128.png"
  },
  "action": {
    "default_popup": "popup/popup.html",
    "default_title": "Verity Settings",
    "default_icon": {
      "128": "icons/icon128.png"
    }
  },
  "content_scripts": [
    {
      "matches": [
        "https://chat.openai.com/*",
        "https://chatgpt.com/*"
      ],
      "js": ["content/interceptor.js"],
      "run_at": "document_start",
      "world": "MAIN"
    },
    {
      "matches": [
        "https://chat.openai.com/*",
        "https://chatgpt.com/*"
      ],
      "js": [
        "content/settings.js",
        "content/api.js",
        "content/extractor.js",
        "content/ui.js",
        "content/observer.js",
        "content/content.js"
      ],
      "css": ["styles/cards.css"],
      "run_at": "document_idle"
    }
  ],
  "background": {
    "service_worker": "background/service-worker.js"
  },
  "web_accessible_resources": [{
    "resources": ["styles/cards.css"],
    "matches": ["https://chat.openai.com/*", "https://chatgpt.com/*"]
  }]
}
