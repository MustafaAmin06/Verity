{
  "manifest_version": 3,
  "name": "Verity",
  "version": "1.0.1",
  "description": "Score the sources behind AI responses.",
  "permissions": ["activeTab", "tabs", "storage"],
  "host_permissions": [
    "http://localhost:8001/*"
  ],
  "action": {
    "default_popup": "popup/popup.html",
    "default_title": "Verity Settings"
  },
  "content_scripts": [
    {
      "matches": [
        "https://chat.openai.com/*",
        "https://chatgpt.com/*"
      ],
      "js": [
        "content/settings.js",
        "content/api.js",
        "content/extractor.js",
        "content/ui.js",
        "content/observer.js",
        "content/content.js"
      ],
      "css": ["styles/cards.css"],
      "run_at": "document_idle"
    }
  ],
  "background": {
    "service_worker": "background/service-worker.js"
  },
  "web_accessible_resources": [{
    "resources": ["styles/cards.css"],
    "matches": ["https://chat.openai.com/*", "https://chatgpt.com/*"]
  }]
}
